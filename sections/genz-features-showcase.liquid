{%- style -%}
  .features-showcase-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    border-top: 1px solid {{ section.settings.border_color | default: '#e5e5e5' }};
    border-bottom: 1px solid {{ section.settings.border_color | default: '#e5e5e5' }};
  }

  .features-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .features-grid-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: stretch;
  }

  /* Dynamic Item Box Layout with elegant grid separator borders */
  .feature-item-box-{{ section.id }} {
    flex: 1;
    min-width: 250px;
    padding: 40px 30px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    transition: transform 0.3s ease;
  }

  /* Creating the divider lines between column blocks like original Ella layout */
  .feature-item-box-{{ section.id }}:not(:last-child) {
    border-right: 1px solid {{ section.settings.border_color | default: '#e5e5e5' }};
  }

  .feature-item-box-{{ section.id }}:hover {
    transform: translateY(-3px);
  }

  /* Icon Frame Container Architecture */
  .feature-icon-wrapper-{{ section.id }} {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin-bottom: 25px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .feature-icon-wrapper-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .feature-icon-wrapper-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ section.settings.icon_color | default: '#111111' }};
  }

  /* Info Meta Layer Content */
  .feature-info-block h4 {
    font-size: 1.15rem;
    font-weight: 700;
    color: {{ section.settings.title_color | default: '#111111' }};
    margin: 0 0 12px 0;
    text-transform: capitalize;
  }

  .feature-info-block p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: {{ section.settings.text_color | default: '#666666' }};
    margin: 0;
    max-width: 280px;
  }

  /* Responsive Fix for tablet and mobile screens */
  @media (max-width: 991px) {
    .feature-item-box-{{ section.id }} {
      flex: 0 0 50%;
      border-bottom: 1px solid {{ section.settings.border_color | default: '#e5e5e5' }};
    }
    .feature-item-box-{{ section.id }}:nth-child(2n) {
      border-right: none;
    }
  }

  @media (max-width: 576px) {
    .feature-item-box-{{ section.id }} {
      flex: 0 0 100%;
      border-right: none !important;
    }
  }
{%- endstyle -%}

<section class="features-showcase-{{ section.id }}">
  <div class="features-container-{{ section.id }}">
    <div class="features-grid-{{ section.id }}">
      
      {% for block in section.blocks %}
        <div class="feature-item-box-{{ section.id }}" {{ block.shopify_attributes }}>
          
          <div class="feature-icon-wrapper-{{ section.id }}">
            {% if block.settings.icon_image != blank %}
              <img src="{{ block.settings.icon_image | img_url: '120x120' }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% else %}
              {% case forloop.index0 %}
                {% when 0 %}
                  <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                {% when 1 %}
                  <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                {% when 2 %}
                  <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                {% else %}
                  <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
              {% endcase %}
            {% endif %}
          </div>

          <div class="feature-info-block">
            <h4>{{ block.settings.title | escape }}</h4>
            <p>{{ block.settings.subtext | escape }}</p>
          </div>

        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "GenZ Features Showcase",
  "max_blocks": 5,
  "settings": [
    {
      "type": "header",
      "content": "Global Layout Config"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1100,
      "max": 1600,
      "step": 50,
      "label": "Container Row Width (px)",
      "default": 1350
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 30,
      "max": 80,
      "step": 5,
      "label": "Icon Box Dimension (px)",
      "default": 45
    },
    {
      "type": "header",
      "content": "Color Palette Management"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Grid Border Line Color",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Default SVG Icon Theme",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Feature Title Font Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subtext Paragraph Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Outer Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "label": "Padding Bottom",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "feature_block",
      "name": "Feature Item Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon Image (PNG/SVG)",
          "info": "Leave blank to render built-in modern minimalist system icons."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Heading",
          "default": "Free Standard Delivery"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Feature Subtext Paragraph",
          "default": "Metus tellus multricies a quam sit amet lorem diam libero de cosmopolis."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GenZ Features Showcase",
      "blocks": [
        { "type": "feature_block", "settings": { "title": "Free Standard Delivery" } },
        { "type": "feature_block", "settings": { "title": "Secure Shopping" } },
        { "type": "feature_block", "settings": { "title": "Shop With Confidence" } },
        { "type": "feature_block", "settings": { "title": "24/7 Help Center" } }
      ]
    }
  ]
}
{% endschema %}