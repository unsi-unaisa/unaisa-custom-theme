{%- style -%}
  .image-banner-section-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.bg_color }};
  }

  .banner-wrapper-{{ section.id }} {
    width: 100%;
    margin: 0 auto;
    {% if section.settings.enable_full_width %}
      max-width: none;
      padding: 0 {{ section.settings.side_padding }}px;
    {% else %}
      max-width: {{ section.settings.custom_max_width }}px;
      padding: 0 20px;
    {% endif %}
  }

  .banner-link-container-{{ section.id }} {
    display: block;
    width: 100%;
    /* Fix: Handling Auto Height vs Fixed Height Dynamic Matrix */
    {% if section.settings.height_style == 'auto' %}
      height: auto;
    {% else %}
      height: {{ section.settings.desktop_height }}px;
    {% endif %}
    overflow: hidden;
    position: relative;
    border-radius: {{ section.settings.corner_radius }}px;
    {% if section.settings.banner_link != blank %}
      cursor: pointer;
    {% else %}
      cursor: default;
    {% endif %}
  }

  .banner-link-container-{{ section.id }} img {
    width: 100%;
    {% if section.settings.height_style == 'auto' %}
      height: auto;
      display: block;
    {% else %}
      height: 100%;
      object-fit: {{ section.settings.image_fit }};
    {% endif %}
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  {% if section.settings.enable_hover_zoom and section.settings.banner_link != blank %}
    .banner-link-container-{{ section.id }}:hover img {
      transform: scale(1.02);
    }
  {% endif %}

  .banner-link-container-{{ section.id }} svg {
    width: 100%;
    height: 360px;
    background-color: #e3e3e3;
    fill: #a1a1a6;
  }
{%- endstyle -%}

<section class="image-banner-section-{{ section.id }}">
  <div class="banner-wrapper-{{ section.id }}">
    
    {% if section.settings.banner_link != blank %}
      <a href="{{ section.settings.banner_link }}" class="banner-link-container-{{ section.id }}">
    {% else %}
      <div class="banner-link-container-{{ section.id }}">
    {% endif %}

      {% if section.settings.banner_image != blank %}
        <img 
          src="{{ section.settings.banner_image | img_url: '1800x' }}" 
          alt="{{ section.settings.banner_image.alt | default: 'Promo Banner Image' }}"
          loading="lazy"
        >
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag }}
      {% endif %}

    {% if section.settings.banner_link != blank %}
      </a>
    {% else %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "GenZ Full Image Banner",
  "settings": [
    {
      "type": "header",
      "content": "Media Source Configuration"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Select Banner Image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner Destination Link"
    },
    {
      "type": "header",
      "content": "Height & Aspect Scaling"
    },
    {
      "type": "select",
      "id": "height_style",
      "label": "Banner Height Mode",
      "options": [
        { "value": "auto", "label": "✨ Auto (Perfect Aspect - No Crop)" },
        { "value": "fixed", "label": "📏 Fixed Custom Height" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 200,
      "max": 600,
      "step": 10,
      "label": "Fixed Desktop Height (px)",
      "default": 360
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Fixed Height Crop Style",
      "options": [
        { "value": "cover", "label": "Cover style" },
        { "value": "contain", "label": "Contain style" }
      ],
      "default": "cover"
    },
    {
      "type": "header",
      "content": "Layout Architecture"
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "Enable True Full Width Layer",
      "default": true
    },
    {
      "type": "range",
      "id": "custom_max_width",
      "min": 1000,
      "max": 1600,
      "step": 10,
      "label": "Boxed Layout Max Width (px)",
      "default": 1370
    },
    {
      "type": "range",
      "id": "side_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Full Width Side Margins (px)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Design Cosmetics & FX"
    },
    {
      "type": "checkbox",
      "id": "enable_hover_zoom",
      "label": "Enable Premium Zoom FX on Hover",
      "default": true
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "label": "Image Corner Radius (px)",
      "default": 0
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Outer Section Background Color",
      "default": "transparent"
    },
    {
      "type": "header",
      "content": "Section Spacing Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "label": "Padding Bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "GenZ Full Image Banner"
    }
  ]
}
{% endschema %}