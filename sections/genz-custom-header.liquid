{%- style -%}
  :root {
    --header-bg: {{ section.settings.header_bg | default: '#ffffff' }};
    --header-text: {{ section.settings.header_text_color | default: '#111111' }};
  }

  /* 1. Announcement Bar Styling */
  .genz-announcement-bar {
    background-color: {{ section.settings.announcement_bg | default: '#111111' }};
    color: {{ section.settings.announcement_text_color | default: '#ffffff' }};
    text-align: center;
    padding: 10px 20px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  /* 2. Main Header Container Architecture */
  .genz-header-wrapper {
    background-color: var(--header-bg);
    border-bottom: 1px solid {{ section.settings.border_color | default: '#e5e5e5' }};
    position: relative;
    z-index: 100;
  }

  .genz-header-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 20px 40px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    box-sizing: border-box;
  }

  /* Left Segment: Clean Search Box Area */
  .header-left-zone {
    display: flex;
    align-items: center;
  }

  .header-search-form {
    display: flex;
    align-items: center;
    border-bottom: 1px solid #cccccc;
    padding-bottom: 4px;
    max-width: 240px;
    width: 100%;
  }

  .header-search-form input {
    border: none;
    background: transparent;
    outline: none;
    font-size: 0.88rem;
    width: 100%;
    color: var(--header-text);
  }

  .header-search-form svg {
    fill: none;
    stroke: var(--header-text);
    margin-right: 8px;
  }

  /* Center Segment: Premium Brand Logo Layer */
  .header-center-zone {
    text-align: center;
  }

  .header-logo-link {
    font-size: 1.6rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--header-text);
  }

  .header-logo-img {
    max-height: {{ section.settings.logo_max_height }}px;
    display: block;
    margin: 0 auto;
  }

  /* Right Segment: Utilities / Icons Layer */
  .header-right-zone {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 25px;
  }

  .header-utility-link {
    color: var(--header-text);
    text-decoration: none;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    position: relative;
  }

  .header-utility-link svg {
    fill: none;
    stroke: var(--header-text);
  }

  .cart-count-badge {
    position: absolute;
    top: -8px;
    right: -10px;
    background: #000000;
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* 3. Navigation Bar Architecture (Ella Demo Dropdown Style) */
  .genz-navigation-row {
    background-color: var(--header-bg);
    border-bottom: 1px solid {{ section.settings.border_color | default: '#e5e5e5' }};
  }

  .nav-menu-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 35px;
  }

  .nav-item-root {
    position: relative;
    padding: 15px 0;
  }

  .nav-link-root {
    color: var(--header-text);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.2s ease;
  }

  .nav-link-root:hover {
    color: #666666;
  }

  /* Dropdown Child Layer Architecture */
  .nav-dropdown-wrapper {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: #ffffff;
    min-width: 200px;
    box-shadow: 0px 10px 30px rgba(0,0,0,0.08);
    padding: 15px 0;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transition: all 0.25s ease;
    border-top: 2px solid #000000;
    z-index: 200;
  }

  .nav-dropdown-wrapper li a {
    display: block;
    padding: 10px 25px;
    color: #111111;
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.2s ease, padding-left 0.2s ease;
  }

  .nav-dropdown-wrapper li a:hover {
    background: #f7f7f7;
    padding-left: 30px;
  }

  .nav-item-root:hover .nav-dropdown-wrapper {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* Responsive Mobile Breakpoints */
  @media (max-width: 991px) {
    .genz-header-container {
      grid-template-columns: 1fr auto;
      padding: 15px 20px;
    }
    .header-left-zone, .genz-navigation-row {
      display: none;
    }
  }
{%- endstyle -%}

<header class="genz-header-main-parent">
  
  {% if section.settings.show_announcement and section.settings.announcement_text != blank %}
    <div class="genz-announcement-bar">
      {{ section.settings.announcement_text | escape }}
    </div>
  {% endif %}

  <div class="genz-header-wrapper">
    <div class="genz-header-container">
      
      <div class="header-left-zone">
        <form action="{{ routes.search_url }}" method="get" role="search" class="header-search-form">
          <svg width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input type="text" name="q" placeholder="Search our store..." autocomplete="off">
        </form>
      </div>

      <div class="header-center-zone">
        <a href="{{ routes.root_url }}" class="header-logo-link">
          {% if section.settings.logo != blank %}
            {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
            <img src="{{ section.settings.logo | img_url: '400x' }}" alt="{{ logo_alt }}" class="header-logo-img" loading="eager">
          {% else %}
            <span>{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>

      <div class="header-right-zone">
        {% if shop.customer_accounts_enabled %}
          <a href="{{ routes.account_url }}" class="header-utility-link" title="Account">
            <svg width="22" height="22" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </a>
        {% endif %}

        <a href="{{ routes.cart_url }}" class="header-utility-link" id="cart-icon-bubble" title="Cart">
          <svg width="22" height="22" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          <span class="cart-count-badge">{{ cart.item_count }}</span>
        </a>
      </div>

    </div>
  </div>

  <nav class="genz-navigation-row">
    <div class="genz-header-container" style="padding-top:0; padding-bottom:0;">
      <ul class="nav-menu-links">
        {% for link in linklists[section.settings.main_menu_linklist].links %}
          <li class="nav-item-root">
            <a href="{{ link.url }}" class="nav-link-root">{{ link.title }}</a>
            
            {% if link.links != blank %}
              <ul class="nav-dropdown-wrapper">
                {% for childlink in link.links %}
                  <li>
                    <a href="{{ childlink.url }}">{{ childlink.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </nav>

</header>

{% schema %}
{
  "name": "GenZ Premium Header",
  "settings": [
    {
      "type": "header",
      "content": "Layout Controls"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1100,
      "max": 1600,
      "step": 50,
      "label": "Header Maximum Width (px)",
      "default": 1350
    },
    {
      "type": "link_list",
      "id": "main_menu_linklist",
      "label": "Select Primary Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Brand Identity Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Brand Logo Image"
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Custom Logo Height Alignment",
      "default": 45
    },
    {
      "type": "header",
      "content": "Announcement Element"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Enable Announcement Bar Component",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Info Content",
      "default": "Mid-Season Sale: Enjoy 20% OFF Everything! Use Code: GENZ20"
    },
    {
      "type": "header",
      "content": "Color Palette Configurations"
    },
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Announcement Bar Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Announcement Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Main Header Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Main Links & Icons Theme Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bottom Grid Separation Line Color",
      "default": "#e5e5e5"
    }
  ]
}
{% endschema %}