{%- style -%}
  .collection-matrix-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.section_bg_color | default: '#ffffff' }};
  }

  .matrix-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .matrix-header-{{ section.id }} {
    margin-bottom: 35px;
  }

  .matrix-header-{{ section.id }} h2 {
    font-size: 2.2rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -1px;
    margin: 0;
    color: {{ section.settings.section_text_color | default: '#1d1d1f' }};
  }

  /* Core Master Grid */
  .grid-layout-{{ section.id }} {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    grid-auto-rows: {{ section.settings.row_height }}px;
    gap: 20px;
  }

  /* Universal Premium Card Design with Absolute Image Overlay */
  .matrix-card {
    border-radius: 4px; /* Matches the clean geometric look of premium catalogs */
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    text-decoration: none;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .matrix-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 25px rgba(0, 0, 0, 0.08);
  }

  /* Assigning row spans to blocks */
  .matrix-card.featured-tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .matrix-card.standard-promo {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Text Layer stacked perfectly on top of the image */
  .matrix-card-content {
    padding: 30px;
    position: relative;
    z-index: 3; /* Forces text to always stay on top */
    width: 100%;
    pointer-events: none;
  }

  .matrix-card-content h3 {
    font-family: 'Arial Black', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 6px 0;
    line-height: 1.1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .matrix-card-content p {
    font-size: 0.95rem;
    margin: 0;
    opacity: 0.8;
    font-weight: 600;
  }

  /* Background Image Container that completely fills the single card */
  .matrix-card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* Stays below the text */
  }

  /* Clean overlay tint option to ensure text readability if image is too bright */
  .matrix-card-image::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 100%);
    z-index: 2;
  }

  .matrix-card-image img, 
  .matrix-card-image .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Forces the image to cover the whole card perfectly */
    object-position: center right; /* Keeps phones and models properly aligned on the right edge */
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .matrix-card:hover .matrix-card-image img {
    transform: scale(1.03); /* Subtle premium zoom on hover */
  }

  /* Responsive Grid Adaptations */
  @media (max-width: 991px) {
    .grid-layout-{{ section.id }} {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 260px;
    }
    .matrix-card.featured-tall {
      grid-column: span 2;
      grid-row: span 1;
    }
  }

  @media (max-width: 576px) {
    .grid-layout-{{ section.id }} {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
    .matrix-card.featured-tall, .matrix-card.standard-promo {
      grid-column: span 1;
    }
    .matrix-card-content { padding: 20px; }
  }
{%- endstyle -%}

<section class="collection-matrix-{{ section.id }}">
  <div class="matrix-container-{{ section.id }}">

    {% if section.settings.title != blank %}
      <div class="matrix-header-{{ section.id }}">
        <h2>{{ section.settings.title }}</h2>
      </div>
    {% endif %}

    <div class="grid-layout-{{ section.id }}">
      {% for block in section.blocks %}
        
        {% if forloop.first %}
          {% assign card_class = 'featured-tall' %}
        {% else %}
          {% assign card_class = 'standard-promo' %}
        {% endif %}

        <a href="{{ block.settings.collection_url | default: '#' }}" class="matrix-card {{ card_class }}" style="background-color: {{ block.settings.card_bg | default: '#f5f5f7' }}; color: {{ block.settings.card_text_color | default: '#1d1d1f' }};" {{ block.shopify_attributes }}>
          
          <div class="matrix-card-content">
            <h3>{{ block.settings.title_text | default: 'Collection' }} <span style="font-size: 0.8em;">❯</span></h3>
            {% if block.settings.subtext != blank %}
              <p>{{ block.settings.subtext }}</p>
            {% endif %}
          </div>

          <div class="matrix-card-image">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: '1000x1000' }}" alt="{{ block.settings.title_text }}">
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>

        </a>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "GenZ Collection Matrix",
  "max_blocks": 5,
  "settings": [
    {
      "type": "header",
      "content": "Global Layout Config"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "SHOP BY CATEGORIES"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1100,
      "max": 1600,
      "step": 50,
      "label": "Container Maximum Width",
      "default": 1300
    },
    {
      "type": "range",
      "id": "row_height",
      "min": 200,
      "max": 400,
      "step": 10,
      "label": "Standard Row Height (px)",
      "default": 250
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Heading Text Color",
      "default": "#1d1d1f"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 5,
      "label": "Padding Top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 5,
      "label": "Padding Bottom",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Category Card",
      "settings": [
        {
          "type": "header",
          "content": "Card Styling & Link"
        },
        {
          "type": "text",
          "id": "title_text",
          "label": "Category Title",
          "default": "SMARTPHONES"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Price Subtext Tag",
          "default": "from $899*"
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Link To Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Full Background Image"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Fallback Background Tint",
          "default": "#f5f5f7"
        },
        {
          "type": "color",
          "id": "card_text_color",
          "label": "Card Text Color",
          "default": "#1d1d1f"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GenZ Collection Matrix",
      "blocks": [
        { "type": "collection_item", "settings": { "title_text": "SMARTPHONES", "subtext": "from $899*", "card_bg": "#fbf1f2" } },
        { "type": "collection_item", "settings": { "title_text": "TABLETS", "subtext": "from $499*", "card_bg": "#fdf7e7" } },
        { "type": "collection_item", "settings": { "title_text": "LAPTOPS", "subtext": "from $899*", "card_bg": "#f4f7f9" } },
        { "type": "collection_item", "settings": { "title_text": "HEADPHONES", "subtext": "from $399*", "card_bg": "#f5f5f7" } },
        { "type": "collection_item", "settings": { "title_text": "SMART TV", "subtext": "from $699*", "card_bg": "#eef7fa" } }
      ]
    }
  ]
}
{% endschema %}