{%- style -%}
  .genz-ticker-wrapper-{{ section.id }} {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;
  }

  .genz-ticker-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.bg_color | default: '#1d1d1f' }};
    width: 100%;
  }

  .ticker-wrap-{{ section.id }} {
    display: flex;
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
  }

  .ticker-track-{{ section.id }} {
    display: flex;
    width: max-content;
    animation: marquee-{{ section.id }} {{ section.settings.speed }}s linear infinite;
    {% if section.settings.direction == 'reverse' %}
      animation-direction: reverse;
    {% endif %}
  }

  {% if section.settings.pause_on_hover %}
    .ticker-wrap-{{ section.id }}:hover .ticker-track-{{ section.id }} {
      animation-play-state: paused;
    }
  {% endif %}

  .ticker-item {
    font-family: 'Impact', 'Arial Black', sans-serif;
    font-size: {{ section.settings.font_size }}rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 0 40px;
    line-height: 1;
    display: flex;
    align-items: center;
    color: {{ section.settings.text_color | default: '#ffffff' }};
  }

  .ticker-item.outline-text {
    color: transparent;
    -webkit-text-stroke: 1px {{ section.settings.text_color | default: '#ffffff' }};
  }

  /* SVG Premium Icon Sizing */
  .ticker-svg-icon {
    display: inline-block;
    width: 0.9em;
    height: 0.9em;
    margin-right: 25px;
    vertical-align: middle;
    fill: currentColor;
  }

  .ticker-dot {
    font-size: {{ section.settings.font_size | divided_by: 2 }}rem;
    margin-left: 60px;
    color: {{ section.settings.accent_color | default: '#ff007f' }};
  }

  @keyframes marquee-{{ section.id }} {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }

  @media (max-width: 767px) {
    .ticker-item {
      font-size: {{ section.settings.font_size | multiplied_by: 0.6 }}rem;
      padding: 0 20px;
    }
  }
{%- endstyle -%}

<div class="genz-ticker-wrapper-{{ section.id }}">
  <section class="genz-ticker-{{ section.id }}">
    <div class="ticker-wrap-{{ section.id }}">
      
      <div class="ticker-track-{{ section.id }}">
        {% for i in (1..3) %}
          {% for block in section.blocks %}
            <div class="ticker-item {% if block.settings.use_outline %}outline-text{% endif %}" {{ block.shopify_attributes }}>
              
              {% if block.settings.icon_select != 'none' %}
                <span class="ticker-svg-icon">
                  {% case block.settings.icon_select %}
                    {% when 'lightning' %}
                      <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    {% when 'fire' %}
                      <svg viewBox="0 0 24 24"><path d="M12 23c-4.97 0-9-4.03-9-9 0-2.12.74-4.07 1.97-5.61L4.35 7.4C3.5 8.79 3 10.39 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.61-1.11-4.96-2.89-6.61L16.69 7c1.43 1.25 2.31 3.08 2.31 5 0 3.87-3.13 7-7 7zm1-17.24V2c-4 1.5-6 5-6 8 0 3.31 2.69 6 6 6s6-2.69 6-6c0-2.2-1-4.5-3-5.24z"/></svg>
                    {% when 'star' %}
                      <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    {% when 'heart' %}
                      <svg viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    {% when 'diamond' %}
                      <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-4.5-4.5L9 11l3 3 6-6 1.41 1.41L12 17z" style="display:none;"/><path d="M12 2L2 12l10 10 10-10L12 2z"/></svg>
                  {% endcase %}
                </span>
              {% endif %}
              
              <span>{{ block.settings.ticker_text | default: 'FUTURE APPARATUS' }}</span>
              
              {% if section.settings.show_dots %}
                <span class="ticker-dot">•</span>
              {% endif %}
            </div>
          {% endfor %}
        {% endfor %}
      </div>

    </div>
  </section>
</div>

{% schema %}
{
  "name": "GenZ Premium Ticker",
  "settings": [
    {
      "type": "header",
      "content": "Slider Physics"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "label": "Animation Speed (Seconds)",
      "default": 15
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Flow Direction",
      "options": [
        { "value": "normal", "label": "Left to Right" },
        { "value": "reverse", "label": "Right to Left" }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Mouse Hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography & Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 2,
      "max": 8,
      "step": 0.5,
      "label": "Font Size (rem)",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Separator Dots",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1d1d1f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Separator Dot Color",
      "default": "#ff007f"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 10,
      "max": 100,
      "step": 5,
      "label": "Padding Top (px)",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 10,
      "max": 100,
      "step": 5,
      "label": "Padding Bottom (px)",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "ticker_item",
      "name": "Text Slide Item",
      "settings": [
        {
          "type": "select",
          "id": "icon_select",
          "label": "Select Premium Icon",
          "options": [
            { "value": "none", "label": "No Icon" },
            { "value": "lightning", "label": "⚡ Lightning Bolt" },
            { "value": "fire", "label": "🔥 Fire Blast" },
            { "value": "star", "label": "⭐ Cyber Star" },
            { "value": "heart", "label": "❤️ Premium Heart" },
            { "value": "diamond", "label": "💎 Luxury Diamond" }
          ],
          "default": "lightning"
        },
        {
          "type": "text",
          "id": "ticker_text",
          "label": "Ticker Text Words",
          "default": "CYBER DROP"
        },
        {
          "type": "checkbox",
          "id": "use_outline",
          "label": "Make this text Outline",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GenZ Premium Ticker",
      "blocks": [
        { "type": "ticker_item", "settings": { "ticker_text": "NEW ARRIVALS", "icon_select": "fire", "use_outline": false } },
        { "type": "ticker_item", "settings": { "ticker_text": "50% OFF", "icon_select": "lightning", "use_outline": true } },
        { "type": "ticker_item", "settings": { "ticker_text": "LIMITED EDITION", "icon_select": "star", "use_outline": false } },
        { "type": "ticker_item", "settings": { "ticker_text": "FUTURE STYLES", "icon_select": "diamond", "use_outline": true } }
      ]
    }
  ]
}
{% endschema %}